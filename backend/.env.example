APP_NAME=PdfORBIT API
APP_ENV=development
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
DOCS_ENABLED=true
LOG_FORMAT=console
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
REQUEST_ID_HEADER=X-Request-ID
CORS_ORIGINS=http://localhost:3000
ALLOWED_HOSTS=*
BUILD_SHA=
COMMIT_REF=
SENTRY_DSN=
DATABASE_URL=postgresql+psycopg://pdforbit:pdforbit@localhost:5432/pdforbit
FILES_ROOT=./var/pdforbit
JWT_ACCESS_SECRET=replace-with-a-32-plus-character-access-secret
JWT_REFRESH_SECRET=replace-with-a-32-plus-character-refresh-secret
DOWNLOAD_SIGNING_SECRET=replace-with-a-32-plus-character-download-secret
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30
DOWNLOAD_URL_TTL_SECONDS=900
PASSWORD_MIN_LENGTH=8
RETENTION_MINUTES=60
GUEST_MAX_UPLOAD_MB=50
USER_MAX_UPLOAD_MB=250
UPLOAD_CHUNK_SIZE_BYTES=1048576
QUEUE_DEFAULT_TIMEOUT_SECONDS=900
CLEANUP_INTERVAL_SECONDS=300
STALE_JOB_THRESHOLD_SECONDS=1800
RATE_LIMIT_UPLOADS_PER_HOUR=60
RATE_LIMIT_JOBS_PER_HOUR=120
RATE_LIMIT_AUTH_ATTEMPTS_PER_HOUR=30
RATE_LIMIT_AUTHENTICATED_MULTIPLIER=4
REDIS_URL=redis://localhost:6379/0
TESSERACT_BIN=tesseract
OCR_TIMEOUT_SECONDS=300
PDF_RENDER_DPI=150
TRANSLATION_PROVIDER=disabled
TRANSLATION_API_KEY=
GROQ_API_KEY=
GROQ_API_BASE=https://api.groq.com/openai/v1
GROQ_TRANSLATE_MODEL=llama-3.3-70b-versatile
GROQ_SUMMARY_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT_SECONDS=120
INTELLIGENCE_CHUNK_CHARS=6000
INTELLIGENCE_SUMMARY_CHUNK_CHARS=10000
INTELLIGENCE_OCR_DPI=300
INTERNAL_ADMIN_ENABLED=false
INTERNAL_ADMIN_EMAIL=
INTERNAL_ADMIN_PASSWORD=
BILLING_INTERNAL_API_SECRET=replace-with-a-32-plus-character-shared-internal-secret
