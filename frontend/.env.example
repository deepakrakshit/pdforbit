# PdfORBIT API base URL
# Set this to your API server URL (no trailing slash)
NEXT_PUBLIC_API_BASE=https://api.pdforbit.app

# Razorpay server-side credentials used by Next.js API routes
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Shared secret for forwarding verified billing events to the backend
BILLING_INTERNAL_API_SECRET=

# Secret configured in the Razorpay webhook dashboard for /api/razorpay-webhook
RAZORPAY_WEBHOOK_SECRET=

# For local development, leave empty to use relative URLs
# NEXT_PUBLIC_API_BASE=
